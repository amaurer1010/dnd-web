# Copy this file to .env and fill in the values

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# A long random string used to sign session cookies — generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Your admin login credentials (set before first run — only used to create the account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Path to your data directory (absolute path on the Pi)
DATA_DIR=/home/pi/dnd-assistant/data

# Path to the web app system prompt
PROMPT_PATH=/home/pi/dnd-web/prompt.md
